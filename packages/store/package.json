{
  "name": "@lunarhue/store",
  "version": "0.1.0",
  "description": "Framework-agnostic state built on top of @tanstack/store with typed plugins and React bindings.",
  "license": "MIT",
  "homepage": "https://github.com/LunarHUE/store#readme",
  "bugs": {
    "url": "https://github.com/LunarHUE/store/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/LunarHUE/store.git",
    "directory": "packages/store"
  },
  "keywords": [
    "state",
    "store",
    "tanstack",
    "react",
    "typescript"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/core/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./plugins/actions": {
      "types": "./dist/plugins/actions/index.d.ts",
      "import": "./dist/plugins/actions/index.js"
    },
    "./plugins/persist": {
      "types": "./dist/plugins/persist/index.d.ts",
      "import": "./dist/plugins/persist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "check": "bun run typecheck && bun run test"
  },
  "dependencies": {
    "@tanstack/react-store": "0.9.2",
    "@tanstack/store": "0.9.2"
  },
  "peerDependencies": {
    "react": "^19.1.1"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "jsdom": "^27.0.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
