{
  "name": "@lunarhue/store",
  "version": "0.4.0",
  "description": "Framework-agnostic state built on top of @tanstack/store with typed plugins and React bindings.",
  "license": "MIT",
  "homepage": "https://github.com/LunarHUE/store#readme",
  "bugs": {
    "url": "https://github.com/LunarHUE/store/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/LunarHUE/store.git",
    "directory": "packages/store"
  },
  "keywords": [
    "state",
    "store",
    "tanstack",
    "react",
    "typescript"
  ],
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./plugins/actions": {
      "types": "./dist/plugins/actions/index.d.ts",
      "import": "./dist/plugins/actions/index.js"
    },
    "./plugins/persist": {
      "types": "./dist/plugins/persist/index.d.ts",
      "import": "./dist/plugins/persist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "contract": "bun run build && node ./scripts/check-package-contract.mjs",
    "test": "bun run test:web && bun run test:native",
    "test:web": "vitest run",
    "test:native": "jest --config ./jest.native.config.cjs",
    "typecheck": "tsc --noEmit",
    "check": "bun run typecheck && bun run test && bun run contract"
  },
  "dependencies": {
    "@tanstack/react-store": "0.9.2",
    "@tanstack/store": "0.9.2"
  },
  "peerDependencies": {
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@swc/core": "1.15.18",
    "@swc/jest": "0.2.39",
    "@testing-library/react": "^16.3.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/react": "^19.2.4",
    "@types/react-dom": "^19.2.3",
    "@types/react-native-web": "^0.19.2",
    "jest": "30.3.0",
    "jest-environment-jsdom": "30.3.0",
    "jsdom": "^29.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-native-web": "0.21.2",
    "react-test-renderer": "19.2.4",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "vitest": "^4.1.0"
  }
}
