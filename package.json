{
  "name": "lunarhue-store-workspace",
  "private": true,
  "packageManager": "bun@1.3.5",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "check": "turbo run check",
    "changeset": "changeset",
    "dev": "turbo run dev --parallel",
    "release:check": "cd packages/store && bun run build && bun run typecheck && bun run test && npm pack --dry-run",
    "release:publish": "bun run release:check && changeset publish",
    "release:version": "changeset version && bun install",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@types/node": "^24.5.2",
    "turbo": "^2.8.20",
    "typescript": "^5.9.2"
  }
}
